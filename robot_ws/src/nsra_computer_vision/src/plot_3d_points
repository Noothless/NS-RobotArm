#!/usr/bin/python
import numpy as np
from mpl_toolkits import mplot3d
import matplotlib.pyplot as plt
import rospy
from std_msgs.msg import String

fig = plt.figure()
ax = plt.axes(projection='3d')

x = np.array([])
y = np.array([])
z = np.array([])

def plot_callback(data):
    xn, yn, zn = data.data.split("/")
    print(xn)
    print(yn)
    print(zn)
    x.append(x, xn)
    x.append(y, yn)
    x.append(z, zn)
    ax.scatter3D(x, y, z, c=1, cmap='Greens')

rospy.init_node('plot_3d_points')
rospy.Subscriber("3DPointCoords", String, plot_callback)

rospy.spin()