import cv2
import numpy as np

c_points = np.float32([[1269.7775,   450.22125],
                       [1275.9633,   501.22632],
                       [1282.4819,   553.8286 ],
                       [1289.4609,   608.8263 ],
                       [1296.682 ,   666.7097 ],
                       [1304.3273,   726.9574 ],
                       [ 791.55316,  453.53558],
                       [ 788.36646,  504.57272],
                       [ 784.35846,  556.81824],
                       [ 780.4502,   611.5713 ],
                       [ 775.78094,  668.07007],
                       [ 770.8579,   727.95135]])

i_points = np.float32([[0  ,  0 ],
                       [0  , 25 ],
                       [0  , 50 ],
                       [0  , 75 ],
                       [0  , 100],
                       [0  , 125],
                       [200, 0  ],
                       [200, 25 ],
